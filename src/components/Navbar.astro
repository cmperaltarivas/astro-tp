---
const currentPath = Astro.url.pathname;

const navItems = [
  {
    label: 'Inicio',
    href: '/',
    icon: 'home',
  },
  {
    label: 'Especialidades',
    icon: 'layers',
    hasDropdown: true,
    subItems: [
      { label: 'Conectividad y Redes', href: '/conectividad-y-redes/' },
      { label: 'Administración', href: '/administracion/' },
      { label: 'Contabilidad', href: '/contabilidad/' },
    ],
  },
  {
    label: 'Noticias',
    href: '/noticias/',
    icon: 'newspaper',
  },
];

const isActive = (href: string) => {
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header class="tp-header">
  <nav class="tp-nav">
    <a href="/" class="tp-logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
      </svg>
      <span>Area Técnico Profesional</span>
    </a>

    <ul class="tp-nav-links" id="nav-links">
      {navItems.map((item) => (
        <li class={item.hasDropdown ? 'has-dropdown' : ''}>
          <a
            href={item.href || '#'}
            class={isActive(item.href || '') ? 'active' : ''}
          >
            {item.label}
          </a>
          {item.hasDropdown && item.subItems && (
            <ul class="tp-dropdown">
              {item.subItems.map((subItem) => (
                <li>
                  <a
                    href={subItem.href}
                    class={isActive(subItem.href) ? 'active' : ''}
                  >
                    {subItem.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <div class="tp-nav-right">
      <button class="tp-search-btn" id="search-toggle" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>

      <button class="tp-theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>

      <button class="tp-menu-toggle" id="menu-toggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .tp-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
  }

  .tp-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 64px;
    padding: 0 2rem;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e2e8f0;
    gap: 2rem;
  }

  :root[data-theme='dark'] .tp-nav {
    background: rgba(15, 23, 42, 0.85);
    border-bottom-color: #334155;
  }

  .tp-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: #1e293b;
    font-weight: 700;
    font-size: 0.95rem;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .tp-logo:hover {
    color: #15803d;
  }

  .tp-logo svg {
    color: #15803d;
    flex-shrink: 0;
  }

  :root[data-theme='dark'] .tp-logo {
    color: #f1f5f9;
  }

  :root[data-theme='dark'] .tp-logo:hover {
    color: #4ade80;
  }

  :root[data-theme='dark'] .tp-logo svg {
    color: #4ade80;
  }

  .tp-nav-links {
    display: none;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 900px) {
    .tp-nav-links {
      display: flex;
    }
  }

  .tp-nav-links > li {
    position: relative;
  }

  .tp-nav-links a {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.875rem;
    text-decoration: none;
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .tp-nav-links a:hover {
    color: #15803d;
    background: rgba(22, 163, 74, 0.08);
  }

  .tp-nav-links a.active {
    color: #15803d;
    background: rgba(22, 163, 74, 0.1);
  }

  :root[data-theme='dark'] .tp-nav-links a {
    color: #94a3b8;
  }

  :root[data-theme='dark'] .tp-nav-links a:hover {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
  }

  :root[data-theme='dark'] .tp-nav-links a.active {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.15);
  }

  .tp-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
    padding: 0.5rem;
    list-style: none;
    margin: 0;
  }

  :root[data-theme='dark'] .tp-dropdown {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .has-dropdown:hover .tp-dropdown {
    display: block;
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  .tp-dropdown a {
    display: block;
    padding: 0.6rem 0.875rem;
    border-radius: 8px;
    color: #1e293b;
    font-size: 0.875rem;
  }

  :root[data-theme='dark'] .tp-dropdown a {
    color: #f1f5f9;
  }

  .tp-dropdown a:hover {
    background: #f1f5f9;
    color: #15803d;
  }

  :root[data-theme='dark'] .tp-dropdown a:hover {
    background: #334155;
    color: #4ade80;
  }

  .tp-nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tp-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tp-search-btn:hover {
    border-color: #15803d;
    color: #15803d;
    background: rgba(22, 163, 74, 0.08);
  }

  :root[data-theme='dark'] .tp-search-btn {
    border-color: #334155;
    color: #94a3b8;
  }

  :root[data-theme='dark'] .tp-search-btn:hover {
    border-color: #4ade80;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
  }

  .tp-theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tp-theme-toggle:hover {
    border-color: #15803d;
    color: #15803d;
    background: rgba(22, 163, 74, 0.08);
  }

  .tp-theme-toggle .icon-sun {
    display: none;
  }

  .tp-theme-toggle .icon-moon {
    display: block;
  }

  :root[data-theme='dark'] .tp-theme-toggle {
    border-color: #334155;
    color: #94a3b8;
  }

  :root[data-theme='dark'] .tp-theme-toggle:hover {
    border-color: #4ade80;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
  }

  :root[data-theme='dark'] .tp-theme-toggle .icon-sun {
    display: block;
  }

  :root[data-theme='dark'] .tp-theme-toggle .icon-moon {
    display: none;
  }

  .tp-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
  }

  .tp-menu-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: #64748b;
    border-radius: 2px;
    transition: all 0.3s;
    margin: 0 auto;
  }

  :root[data-theme='dark'] .tp-menu-toggle {
    border-color: #334155;
  }

  :root[data-theme='dark'] .tp-menu-toggle span {
    background: #94a3b8;
  }

  @media (min-width: 900px) {
    .tp-menu-toggle {
      display: none;
    }
  }

  .tp-menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .tp-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .tp-menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 899px) {
    .tp-nav {
      height: auto;
      min-height: 60px;
      padding: 0.75rem 1rem;
      flex-wrap: wrap;
    }

    .tp-nav-links {
      display: none;
      width: 100%;
      flex-direction: column;
      padding-top: 1rem;
      margin-top: 0.75rem;
      border-top: 1px solid #e2e8f0;
      gap: 0.25rem;
    }

    :root[data-theme='dark'] .tp-nav-links {
      border-top-color: #334155;
    }

    .tp-nav-links.active {
      display: flex;
    }

    .tp-nav-links a {
      padding: 0.75rem 1rem;
    }

    .tp-dropdown {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      background: transparent;
      padding-left: 1rem;
    }

    :root[data-theme='dark'] .tp-dropdown {
      background: transparent;
    }

    .tp-dropdown a {
      padding: 0.5rem 1rem;
      color: #64748b;
    }

    :root[data-theme='dark'] .tp-dropdown a {
      color: #94a3b8;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const navLinks = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('active');
    navLinks?.classList.toggle('active');
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.tp-nav')) {
      toggle?.classList.remove('active');
      navLinks?.classList.remove('active');
    }
  });

  const searchBtn = document.getElementById('search-toggle');
  searchBtn?.addEventListener('click', () => {
    const searchModal = document.querySelector('starlight-search');
    const searchButton = searchModal?.querySelector('button');
    (searchButton as HTMLButtonElement)?.click();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      const searchModal = document.querySelector('starlight-search');
      const searchButton = searchModal?.querySelector('button');
      (searchButton as HTMLButtonElement)?.click();
    }
  });

  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const currentTheme = html.dataset.theme;
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    html.dataset.theme = newTheme;
    localStorage.setItem('starlight-theme', newTheme);
  });
</script>