---
const currentPath = Astro.url.pathname;

const navItems = [
  {
    label: 'Inicio',
    href: '/',
    icon: 'home',
  },
  {
    label: 'Especialidades',
    icon: 'layers',
    hasDropdown: true,
    subItems: [
      { label: 'Conectividad y Redes', href: '/conectividad-y-redes/' },
      { label: 'Administracion', href: '/administracion/' },
      { label: 'Contabilidad', href: '/contabilidad/' },
    ],
  },
  {
    label: 'Noticias',
    href: '/noticias/',
    icon: 'newspaper',
  },
];

const isActive = (href: string) => {
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header class="tp-header">
  <nav class="tp-nav">
    <div class="tp-nav-container">
      <a href="/" class="tp-logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
        <span class="tp-logo-text">Area TP</span>
      </a>

      <div class="tp-nav-right">
        <button class="tp-search-btn" id="search-toggle" aria-label="Buscar">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <span>Buscar...</span>
          <kbd>Ctrl K</kbd>
        </button>

        <button class="tp-theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </button>

        <button class="tp-menu-toggle" id="menu-toggle" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <ul class="tp-nav-links" id="nav-links">
        {navItems.map((item) => (
          <li class={item.hasDropdown ? 'has-dropdown' : ''}>
            <a
              href={item.href || '#'}
              class={isActive(item.href || '') ? 'active' : ''}
            >
              {item.icon === 'home' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
              {item.icon === 'layers' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.91a1 1 0 0 0 0-1.83Z"/><path d="m22 12-8.18 3.72a2 2 0 0 1-1.64 0L2 12"/><path d="m22 17-8.18-3.72a2 2 0 0 0-1.64 0L2 17"/></svg>
              )}
              {item.icon === 'newspaper' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8M15 18h-5M10 6h8v4h-8z"/></svg>
              )}
              <span>{item.label}</span>
            </a>
            {item.hasDropdown && item.subItems && (
              <ul class="tp-dropdown">
                {item.subItems.map((subItem) => (
                  <li>
                    <a
                      href={subItem.href}
                      class={isActive(subItem.href) ? 'active' : ''}
                    >
                      {subItem.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .tp-header {
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .tp-nav {
    background: linear-gradient(135deg, #15803d 0%, #16a34a 100%);
    border-bottom: none;
    box-shadow: 0 4px 20px rgba(21, 128, 61, 0.25);
  }

  :root[data-theme='dark'] .tp-nav {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .tp-nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1rem;
  }

  .tp-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    transition: opacity 0.2s;
  }

  .tp-logo:hover {
    opacity: 0.9;
  }

  .tp-logo svg {
    color: #fff;
  }

  .tp-logo-text {
    display: none;
  }

  @media (min-width: 640px) {
    .tp-logo-text {
      display: inline;
    }
  }

  .tp-nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tp-search-btn {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tp-search-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .tp-search-btn kbd {
    display: none;
    padding: 0.15rem 0.35rem;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    font-size: 0.7rem;
    font-family: inherit;
  }

  @media (min-width: 768px) {
    .tp-search-btn {
      display: flex;
    }
    .tp-search-btn kbd {
      display: inline;
    }
  }

  .tp-theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 8px;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s;
  }

  .tp-theme-toggle:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .tp-theme-toggle .icon-sun {
    display: none;
  }

  .tp-theme-toggle .icon-moon {
    display: block;
  }

  :root[data-theme='dark'] .tp-theme-toggle .icon-sun {
    display: block;
  }

  :root[data-theme='dark'] .tp-theme-toggle .icon-moon {
    display: none;
  }

  .tp-menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .tp-menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .tp-menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .tp-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .tp-menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (min-width: 900px) {
    .tp-menu-toggle {
      display: none;
    }
  }

  .tp-nav-links {
    display: none;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    flex-direction: column;
    background: linear-gradient(135deg, #15803d 0%, #16a34a 100%);
    padding: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    list-style: none;
    margin: 0;
  }

  :root[data-theme='dark'] .tp-nav-links {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  }

  .tp-nav-links.active {
    display: flex;
  }

  @media (min-width: 900px) {
    .tp-nav-links {
      display: flex;
      position: static;
      flex-direction: row;
      border: none;
      padding: 0;
      gap: 0.25rem;
    }
  }

  .tp-nav-links > li {
    position: relative;
  }

  .tp-nav-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .tp-nav-links a:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
  }

  .tp-nav-links a.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
  }

  .tp-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    padding: 0.5rem;
    list-style: none;
    margin: 0;
  }

  :root[data-theme='dark'] .tp-dropdown {
    background: #1e293b;
    border-color: #334155;
  }

  .has-dropdown:hover .tp-dropdown {
    display: block;
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tp-dropdown a {
    display: block;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    color: #1e293b;
  }

  :root[data-theme='dark'] .tp-dropdown a {
    color: #f1f5f9;
  }

  .tp-dropdown a:hover {
    background: #f1f5f9;
    color: #15803d;
  }

  :root[data-theme='dark'] .tp-dropdown a:hover {
    background: #334155;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const navLinks = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('active');
    navLinks?.classList.toggle('active');
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.tp-nav')) {
      toggle?.classList.remove('active');
      navLinks?.classList.remove('active');
    }
  });

  const searchBtn = document.getElementById('search-toggle');
  searchBtn?.addEventListener('click', () => {
    const searchModal = document.querySelector('starlight-search');
    const searchButton = searchModal?.querySelector('button');
    (searchButton as HTMLButtonElement)?.click();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      const searchModal = document.querySelector('starlight-search');
      const searchButton = searchModal?.querySelector('button');
      (searchButton as HTMLButtonElement)?.click();
    }
  });

  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const currentTheme = html.dataset.theme;
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    html.dataset.theme = newTheme;
    localStorage.setItem('starlight-theme', newTheme);
  });
</script>